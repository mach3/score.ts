{
  "name": "score.ts",
  "version": "0.8.0",
  "description": "A 16-step sequencer library built with Web Audio API and TypeScript, featuring chord-based tone generation with 48 chords, 6 traditional scales, and 10 sound presets",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "scripts": {
    "example": "parcel example/index.html --dist-dir .parcel-dist",
    "build:example": "parcel build example/index.html --dist-dir .pages-dist --public-url /score.ts/",
    "build": "rimraf ./dist/* && npm run build:esm && npm run build:cjs",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write ."
  },
  "targets": {
    "main": false,
    "module": false,
    "types": false
  },
  "author": "mach3",
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@parcel/transformer-sass": "^2.16.4",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "jest": "^30.4.2",
    "parcel": "^2.16.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-icons": "^5.6.0",
    "rimraf": "^6.1.3",
    "styled-components": "^6.4.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
